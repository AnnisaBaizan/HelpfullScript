# ============================================================
# VoiceScribe AI — Konfigurasi Environment Variables
# ============================================================
# Salin file ini menjadi .env.local dan isi dengan API key Anda
# Minimal satu provider transkripsi & satu provider AI wajib diisi
# ============================================================

# ═══════════════════════════════════════════════════════════
# TRANSKRIPSI AUDIO (minimal isi 1)
# Urutan fallback: Groq → AssemblyAI → HuggingFace → Deepgram → Gladia
# ═══════════════════════════════════════════════════════════

# ── Provider 1: Groq Whisper ─────────────────────────────
# Daftar gratis: https://console.groq.com
# Batas: 25MB per file · Sangat cepat · Gratis
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Provider 2: AssemblyAI ───────────────────────────────
# Daftar gratis: https://www.assemblyai.com
# Batas: 1GB per file · 100 jam gratis · Support Bahasa Indonesia
ASSEMBLYAI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Provider 3: HuggingFace Whisper ─────────────────────
# Daftar gratis: https://huggingface.co/settings/tokens
# Batas: Gratis selamanya · Lebih lambat
HUGGINGFACE_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Provider 4: Deepgram Nova-2 ──────────────────────────
# Daftar gratis: https://console.deepgram.com
# Batas: $200 kredit gratis saat daftar · Akurasi tinggi · Cepat
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Provider 5: Gladia ───────────────────────────────────
# Daftar gratis: https://app.gladia.io
# Batas: 10 jam/bulan gratis · Async · Support banyak bahasa
GLADIA_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ═══════════════════════════════════════════════════════════
# RINGKASAN & ANALISIS AI (minimal isi 1)
# Urutan fallback: Groq LLaMA → OpenRouter → Google Gemini
# ═══════════════════════════════════════════════════════════

# ── Provider 1: Groq LLaMA (sudah diisi di atas) ─────────
# GROQ_API_KEY dipakai ulang untuk ringkasan — tidak perlu isi lagi

# ── Provider 2: OpenRouter ───────────────────────────────
# Daftar gratis: https://openrouter.ai
# Model: meta-llama/llama-3.1-8b-instruct:free (gratis selamanya)
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Provider 3: Google Gemini ────────────────────────────
# Daftar gratis: https://aistudio.google.com/apikey
# Model: gemini-1.5-flash-8b · 1500 req/hari gratis
GOOGLE_AI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
